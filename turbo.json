{
    "$schema":  "https://turborepo.com/schema.json",
    "tasks":  {
                  "dev":  {
                              "cache":  false,
                              "persistent":  true
                          },
                  "build":  {
                                "dependsOn":  [
                                                  "^build"
                                              ],
                                "outputs":  [
                                                ".next/**",
                                                "dist/**"
                                            ]
                            },
                  "lint":  {
                               "dependsOn":  [
                                                 "^lint"
                                             ]
                           },
                  "typecheck":  {
                                    "dependsOn":  [
                                                      "^typecheck"
                                                  ]
                                }
              },
    "globalEnv":  [
                      "NEXT_PUBLIC_CONVEX_URL",
                      "NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY",
                      "CLERK_SECRET_KEY",
                      "NEXT_PUBLIC_SENTRY_DSN",
                      "SENTRY_DSN",
                      "SENTRY_ORG",
                      "SENTRY_PROJECT",
                      "SENTRY_AUTH_TOKEN",
                      "SENTRY_ENFORCE_DSN",
                      "SENTRY_TRACES_SAMPLE_RATE",
                      "NEXT_PUBLIC_SENTRY_TRACES_SAMPLE_RATE",
                      "SENTRY_ENVIRONMENT",
                      "NEXT_PUBLIC_APP_ENV",
                      "CONVEX_DEPLOYMENT",
                      "CONVEX_URL",
                      "CONVEX_SITE_URL",
                      "CLERK_JWT_ISSUER_DOMAIN"
                  ]
}
