# Convex development deployment
CONVEX_DEPLOYMENT=dev:your-development-deployment
CONVEX_URL=https://your-development-deployment.convex.cloud
CONVEX_SITE_URL=https://your-development-deployment.convex.site

# Convex auth provider
CLERK_JWT_ISSUER_DOMAIN=https://your-development-instance.clerk.accounts.dev

# Dashboard auth and Convex client
NEXT_PUBLIC_CONVEX_URL=https://your-development-deployment.convex.cloud
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_your_publishable_key
CLERK_SECRET_KEY=sk_test_your_secret_key
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
